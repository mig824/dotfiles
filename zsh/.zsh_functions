# Claude Code workflow functions for tmux + git worktrees

# cc - Start Claude Code in current directory in a new tmux window
cc() {
  local name="${1:-claude}"
  tmux new-window -n "$name" "claude"
}

# ccw - Start Claude Code in a new git worktree + tmux window
# Usage: ccw <branch-name> [base-branch]
# Example: ccw fix-auth-bug master
ccw() {
  local branch="$1"
  local base="${2:-HEAD}"

  if [[ -z "$branch" ]]; then
    echo "Usage: ccw <branch-name> [base-branch]"
    echo "Creates a worktree at ~/src/<branch-name> and opens Claude Code in it"
    return 1
  fi

  local worktree_path="$HOME/src/$branch"

  if [[ -d "$worktree_path" ]]; then
    echo "Worktree already exists at $worktree_path, opening Claude there..."
  else
    git worktree add "$worktree_path" -b "$branch" "$base"
    if [[ $? -ne 0 ]]; then
      echo "Failed to create worktree"
      return 1
    fi
    echo "Created worktree at $worktree_path"
  fi

  tmux new-window -n "$branch" -c "$worktree_path" "claude"
}

# ccs - Start Claude Code side-by-side with nvim in a tmux split
# Opens nvim on the left, Claude Code on the right
ccs() {
  local name="${1:-claude}"
  tmux new-window -n "$name"
  tmux send-keys "nvim" Enter
  tmux split-window -h -l 50%
  tmux send-keys "claude" Enter
  # Focus the Claude pane (right side)
  tmux select-pane -R
}

# ccls - List all tmux windows running Claude Code
ccls() {
  tmux list-windows -F '#I:#W #{pane_current_command}' | grep -i claude
}

# ccd - Open diffview in nvim for the current branch vs base
# Usage: ccd [base-branch]
ccd() {
  local base="${1:-master}"
  nvim -c "DiffviewOpen $base...HEAD"
}
